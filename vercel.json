{
  "headers": [
    {
      "source": "/fonts/inter-var-latin.woff2",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "crons": [
    { "path": "/api/cron/mtvpls", "schedule": "0 1 * * *" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
